---
import PublicLayout from '@/layouts/PublicLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import TrustMarquee from '@/components/sections/TrustMarquee.astro';
import Services from '@/components/sections/Services.astro';
import Work from '@/components/sections/Work.astro';
import Stats from '@/components/sections/Stats.astro';
import Packages from '@/components/sections/Packages.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import Booking from '@/components/sections/Booking.astro';

/* Conversion-first order: pricing right after proof (stats), social proof
   after, FAQ + booking to close. Founder, process and the brand showcase
   live on /nosotros — keeps the landing focused (especially on mobile)
   while the E-E-A-T content gets its own indexed page. */
---

<PublicLayout>
  <Hero />
  <TrustMarquee />
  <Services />
  <Work />
  <Stats />
  <Packages />
  <Testimonials />
  <Booking />
</PublicLayout>
