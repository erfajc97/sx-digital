---
import '@/styles/fonts.css';
import '@/styles/global.css';
import LangSuggest from '@/components/LangSuggest.astro';
import { getDict, altPathFor, defaultLocale, type Locale } from '@/i18n';

interface Props {
  title?: string;
  description?: string;
}

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const { brand, services, founder, ui, seo } = getDict(locale);

const { title = ui.defaultTitle, description = brand.tagline } = Astro.props;

const origin = Astro.site ? Astro.site.origin : `https://${brand.domain}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = `${origin}/og-cover.jpg`;
const logoImage = `${origin}/solvyxX-3D.jpg`;

/* hreflang pair: this page in the other language (when a counterpart exists). */
const otherLocale: Locale = locale === 'en' ? 'es' : 'en';
const altPath = altPathFor(Astro.url.pathname, otherLocale);
const altHref = altPath ? new URL(altPath, origin).href : undefined;
const esHref = locale === 'es' ? canonical : altHref;
const enHref = locale === 'en' ? canonical : altHref;

// Structured data (JSON-LD) — Organization + WebSite + Service catalog.
// FAQPage schema intentionally omitted on the landing (it lives on /preguntas).
// Organization signals power AI Overviews / GEO citations. The @ids are
// locale-independent (same entities); descriptions follow the page language.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${origin}/#organization`,
      name: brand.name,
      alternateName: 'SolvyX Digital',
      url: origin,
      logo: logoImage,
      image: ogImage,
      email: brand.email,
      telephone: brand.phone,
      slogan: seo.slogan,
      description: seo.orgDescription,
      knowsAbout: seo.knowsAbout,
      sameAs: brand.social.map((s) => s.href),
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'sales',
        email: brand.email,
        telephone: brand.phone,
        areaServed: 'Worldwide',
        availableLanguage: ['es', 'en'],
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Barcelona',
        addressRegion: 'Cataluña',
        addressCountry: 'ES',
      },
      foundingLocation: { '@type': 'Place', name: 'Barcelona, España' },
      founder: { '@id': `${origin}/#founder` },
    },
    {
      '@type': 'Person',
      '@id': `${origin}/#founder`,
      name: founder.name,
      jobTitle: founder.role,
      description: founder.bio,
      worksFor: { '@id': `${origin}/#organization` },
      knowsAbout: seo.founderKnows,
      sameAs: [founder.linkedin, founder.github],
    },
    {
      '@type': 'WebSite',
      '@id': `${origin}/#website`,
      url: origin,
      name: brand.name,
      inLanguage: locale,
      publisher: { '@id': `${origin}/#organization` },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${origin}/#service`,
      name: brand.name,
      url: origin,
      image: ogImage,
      description: seo.serviceDescription,
      serviceType: seo.serviceTypes,
      priceRange: '$$$',
      areaServed: 'Worldwide',
      provider: { '@id': `${origin}/#organization` },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: locale === 'en' ? 'Services' : 'Servicios',
        itemListElement: services.map((s) => ({
          '@type': 'Offer',
          itemOffered: { '@type': 'Service', name: s.title, description: s.description },
        })),
      },
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=5" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=5" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=5" />
    <link rel="canonical" href={canonical} />
    {esHref && <link rel="alternate" hreflang="es" href={esHref} />}
    {enHref && <link rel="alternate" hreflang="en" href={enHref} />}
    {esHref && <link rel="alternate" hreflang="x-default" href={esHref} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'es_ES'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={seo.ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={seo.ogAlt} />
    <meta name="theme-color" content="#3b5bdb" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts: self-hosted Clash Display + Satoshi (same-origin, no render-blocking external request) -->
    <link rel="preload" href="/fonts/satoshi-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/clash-display-600.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-canvas"
    >
      {ui.nav.skip}
    </a>
    <slot />
    <LangSuggest />
  </body>
</html>
