---
import BaseLayout from './BaseLayout.astro';
import IntroGate from '@/components/IntroGate.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ContactModal from '@/components/ContactModal.astro';
import { brand } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  /** Show the cinematic intro gate (landing only by default elsewhere). */
  intro?: boolean;
  /** Solid navbar from the top — for pages without the dark hero. */
  solidNav?: boolean;
}

const { title, description, intro = true, solidNav = false } = Astro.props;
const calLink = brand.calLink;
const calNs = brand.calNamespace;
---

<BaseLayout title={title} description={description}>
  {intro && <IntroGate />}
  <span id="top"></span>
  <Navbar solid={solidNav} />
  <main id="contenido">
    <slot />
  </main>
  <Footer />
  <ContactModal />

  <!-- Scroll reveal: toggles .is-visible on [data-reveal] elements -->
  <script>
    const items = document.querySelectorAll<HTMLElement>('[data-reveal]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce || !('IntersectionObserver' in window)) {
      items.forEach((el) => el.classList.add('is-visible'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      items.forEach((el) => io.observe(el));
    }
  </script>

  <!-- v2 progressive enhancements: count-up, pointer tilt, lazy hero video -->
  <script>
    import '@/scripts/enhance';
  </script>

  <!-- Cal.com popup — namespaced + preloaded so a single modal instance opens
       instantly (no cold loader) and never leaks duplicate boxes. Elements with
       data-cal-namespace + data-cal-link open it; href is the no-JS fallback. -->
  <script is:inline define:vars={{ calLink, calNs }}>
    (function (C, A, L) {
      let p = function (a, ar) {
        a.q.push(ar);
      };
      let d = C.document;
      C.Cal =
        C.Cal ||
        function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement('script')).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () {
              p(api, arguments);
            };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === 'string') {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ['initNamespace', namespace]);
            } else p(cal, ar);
            return;
          }
          p(cal, ar);
        };
    })(window, 'https://app.cal.com/embed/embed.js', 'init');

    Cal('init', { origin: 'https://cal.com' });
    Cal('ui', {
      theme: 'dark',
      cssVarsPerTheme: { dark: { 'cal-brand': '#6f8cf0' } },
      hideEventTypeDetails: false,
      layout: 'month_view',
    });
    // Booking trigger on any [data-cal-link] click.
    //  · Desktop → open the modal IN PLACE (we drive Cal's GLOBAL modal API
    //    explicitly; the namespaced one leaves an orphan "loading" box, and we
    //    sweep any leftover box so no stale loader lingers).
    //  · Mobile → let the href navigate to the full-screen Cal page; the cramped
    //    modal (calendar + a long scroll to the time slots) is poor UX on phones.
    document.addEventListener('click', function (e) {
      const el = e.target.closest && e.target.closest('[data-cal-link]');
      if (!el) return;
      if (window.matchMedia('(max-width: 767px)').matches) return; // full-page on mobile
      e.preventDefault();
      document.querySelectorAll('cal-modal-box').forEach(function (b) {
        b.remove();
      });
      Cal('modal', {
        calLink: el.getAttribute('data-cal-link'),
        config: { layout: 'month_view' },
      });
    });
  </script>
</BaseLayout>
