---
import SectionHeading from '../ui/SectionHeading.astro';
import { getDict, defaultLocale, type Locale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const { process, ui } = getDict(locale);
const t = ui.processSection;
---

<section id="proceso" class="relative scroll-mt-24 overflow-hidden bg-night py-[var(--spacing-section)]">
  <div class="bg-grid-night pointer-events-none absolute inset-0 opacity-50"></div>
  <div
    class="glow-spot"
    style="width:34rem;height:34rem;left:50%;top:-10rem;transform:translateX(-50%);background:oklch(0.52 0.193 264 / 0.28);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-[1240px] px-4 sm:px-6">
    <SectionHeading tone="night" eyebrow={t.eyebrow} title={t.title} description={t.description} />

    <ol class="mt-14 grid gap-px overflow-hidden rounded-[var(--radius-xl2)] border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
      {
        process.map((p, i) => (
          <li
            data-reveal
            style={`--reveal-delay: ${i * 80}ms;`}
            class="group flex flex-col gap-4 bg-night p-7 transition-colors duration-300 hover:bg-night-2"
          >
            <div class="flex items-baseline justify-between">
              <span class="text-gradient font-display text-5xl font-semibold">{p.step}</span>
              <span class="h-px flex-1 translate-y-[-6px] bg-white/10 group-last:hidden ml-4"></span>
            </div>
            <h3 class="text-xl text-on-night">{p.title}</h3>
            <p class="leading-relaxed text-on-night-muted">{p.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
