---
import { clients } from '@/data/site';
// Duplicated list so the -50% translate loops seamlessly.
const loop = [...clients, ...clients];
---

<section class="border-y border-border bg-surface py-10">
  <div class="mx-auto max-w-[1240px] px-4 sm:px-6">
    <p class="mb-7 text-center text-xs uppercase tracking-[0.2em] text-muted">
      Equipos que confían en nosotros para construir
    </p>
    <div class="marquee relative overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_12%,black_88%,transparent)]">
      <ul class="marquee-track flex w-max items-center gap-12">
        {
          loop.map((name) => (
            <li class="shrink-0 font-display text-xl font-semibold text-ink-soft/70 transition-colors hover:text-ink">
              {name}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
