---
import { work } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';

// Asymmetric 12-col rhythm: 7/5 then 5/7.
const span = ['lg:col-span-7', 'lg:col-span-5', 'lg:col-span-5', 'lg:col-span-7'];
---

<section id="trabajo" class="scroll-mt-24 bg-surface py-[var(--spacing-section)]">
  <div class="mx-auto max-w-[1240px] px-4 sm:px-6">
    <SectionHeading
      eyebrow="Trabajo seleccionado"
      title="Productos en producción, no maquetas"
      description="Una muestra de lo que hemos construido para equipos que necesitaban resultados, no promesas."
    />

    <div class="mt-12 grid gap-5 lg:grid-cols-12">
      {
        work.map((item, i) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
            style={`--reveal-delay: ${i * 90}ms;`}
            class:list={[
              'group press relative flex flex-col overflow-hidden rounded-[var(--radius-xl2)] border border-border bg-canvas transition-all duration-300 ease-[var(--ease-snappy)] hover:border-border-strong hover:shadow-[var(--shadow-lift)]',
              span[i] ?? 'lg:col-span-6',
            ]}
          >
            <div class="relative aspect-[16/10] overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                loading="lazy"
                width="1200"
                height="750"
                class="size-full object-cover transition-transform duration-[600ms] ease-[var(--ease-snappy)] group-hover:scale-[1.04]"
              />
              <span class="absolute right-4 top-4 rounded-full bg-canvas/90 px-3 py-1.5 font-display text-sm font-semibold text-ink backdrop-blur">
                {item.result}
              </span>
            </div>

            <div class="flex flex-1 flex-col gap-4 p-7">
              <div class="flex flex-col gap-2">
                <span class="text-xs font-medium uppercase tracking-[0.14em] text-brand">
                  {item.category}
                </span>
                <h3 class="text-2xl text-ink">{item.title}</h3>
                <p class="leading-relaxed text-muted" style="max-width: 52ch;">
                  {item.blurb}
                </p>
              </div>

              <div class="mt-auto flex items-center justify-between pt-2">
                <ul class="flex flex-wrap gap-2">
                  {item.tags.map((t) => (
                    <li class="rounded-full bg-surface-2 px-2.5 py-1 text-xs text-ink-soft">
                      {t}
                    </li>
                  ))}
                </ul>
                <span class="grid size-9 shrink-0 place-items-center rounded-full bg-ink text-canvas transition-transform duration-200 ease-[var(--ease-snappy)] group-hover:rotate-[-45deg]">
                  <Icon name="arrow" class="size-4" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
