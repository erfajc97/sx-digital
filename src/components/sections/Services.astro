---
import { services } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';

// On-brand cobalt → navy gradient per card (subtle depth variation only).
const visual: Record<string, string> = {
  'ai-automation': 'from-[oklch(0.5_0.2_264)] to-[oklch(0.24_0.1_266)]',
  growth: 'from-[oklch(0.46_0.18_262)] to-[oklch(0.25_0.1_264)]',
  media: 'from-[oklch(0.45_0.17_268)] to-[oklch(0.24_0.1_266)]',
  fintech: 'from-[oklch(0.47_0.18_260)] to-[oklch(0.25_0.1_263)]',
  mobile: 'from-[oklch(0.45_0.17_266)] to-[oklch(0.24_0.1_265)]',
  software: 'from-[oklch(0.48_0.19_264)] to-[oklch(0.24_0.1_264)]',
};
const category: Record<string, string> = {
  'ai-automation': 'Automatización',
  growth: 'Marketing IA',
  media: 'Contenido IA',
  fintech: 'Fintech',
  mobile: 'Apps',
  software: 'Software',
};
---

<section id="servicios" class="relative scroll-mt-24 bg-surface">
  <div class="mx-auto max-w-[1240px] px-4 pt-[var(--spacing-section)] sm:px-6">
    <SectionHeading
      eyebrow="Lo que hacemos por ti"
      title="IA que hace crecer tu negocio, y software que lo sostiene"
      description="Gira la rueda con el scroll: cada servicio entra al visor con su explicación. Automatización, marketing y contenido con IA — y el software, las apps y la fintech que lo respaldan."
    />
  </div>

  <!-- Scroll-driven "View-Master" reel (desktop: text left + wheel right;
       mobile: text top + wheel below — same native-scroll-driven rotation) -->
  <div id="svc-reel" class="relative mt-4">
    <div
      class="reel-stage relative mx-auto flex min-h-screen max-w-[1240px] flex-col items-center justify-center gap-2 px-6 lg:flex-row lg:gap-6"
    >
      <!-- Informative text (one per service, cross-faded) -->
      <div class="relative z-10 h-[290px] w-full max-w-md lg:h-[360px] lg:w-[42%] lg:max-w-none">
        {
          services.map((s, i) => (
            <div
              class="reel-text absolute inset-0 flex flex-col justify-center gap-4"
              data-i={i}
              style={i === 0 ? '' : 'opacity:0;visibility:hidden;'}
            >
              <span class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-brand">
                <span class="h-px w-6 bg-brand" />
                {category[s.id]}
              </span>
              <h3 class="font-display text-[clamp(1.9rem,3vw,2.7rem)] font-semibold leading-[1.1] text-ink">
                {s.title}
              </h3>
              <p class="text-lg leading-relaxed text-muted" style="max-width: 42ch;">
                {s.description}
              </p>
              <ul class="flex flex-wrap gap-2 pt-1">
                {s.bullets.map((b) => (
                  <li class="inline-flex items-center gap-1.5 rounded-full bg-canvas px-3 py-1 text-xs text-ink-soft ring-1 ring-border">
                    <Icon name="check" class="size-3.5 text-brand" />
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- The rotating reel of media frames -->
      <div class="reel-wheel relative h-[46vh] w-full lg:h-screen lg:w-[58%]">
        <!-- faint reel guide circle -->
        <div
          class="reel-guide pointer-events-none absolute left-1/2 top-1/2 size-[290px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed border-border lg:size-[440px]"
        >
        </div>
        {
          services.map((s, i) => (
            <div
              class="reel-frame absolute left-1/2 top-1/2 grid h-[200px] w-[156px] place-items-center overflow-hidden rounded-[var(--radius-card)] border border-border card-3d lg:h-[300px] lg:w-[232px] lg:rounded-[var(--radius-xl2)]"
              data-i={i}
            >
              <div class:list={['absolute inset-0 bg-gradient-to-br', visual[s.id] ?? visual.software]} />
              <div class="bg-grid-night absolute inset-0 opacity-25" />
              <Icon name={s.icon} class="relative size-16 text-white" />
              <span class="absolute inset-x-0 bottom-4 text-center text-[11px] font-medium uppercase tracking-[0.16em] text-white/80">
                {category[s.id]}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Reduced-motion fallback (any size): swipe carousel of product cards -->
  <div class="svc-mobile mt-8 hidden">
    <div
      id="svc-track"
      class="flex gap-4 overflow-x-auto px-4 pb-4 [scrollbar-width:none] snap-x snap-mandatory"
    >
      {
        services.map((s) => {
          const featured = s.id === 'ai-automation';
          return (
            <article class="svc-mcard group relative flex h-[58vh] max-h-[500px] w-[80vw] max-w-[320px] shrink-0 snap-center flex-col overflow-hidden rounded-[var(--radius-xl2)] border border-border bg-canvas card-3d will-change-transform">
              <div class:list={['relative h-[44%] overflow-hidden bg-gradient-to-br', visual[s.id] ?? visual.software]}>
                <div class="bg-grid-night absolute inset-0 opacity-25" />
                <Icon name={s.icon} class="pointer-events-none absolute -bottom-8 -right-6 size-40 text-white/10" />
                <span class="absolute left-5 top-5 grid size-11 place-items-center rounded-2xl bg-white/15 text-white ring-1 ring-white/25 backdrop-blur">
                  <Icon name={s.icon} class="size-6" />
                </span>
                <span class="absolute right-5 top-6 text-[11px] font-medium uppercase tracking-[0.16em] text-white/70">
                  {category[s.id]}
                </span>
                {featured && (
                  <span class="absolute bottom-4 left-5 rounded-full bg-white/15 px-3 py-1 text-[11px] font-medium uppercase tracking-wider text-white backdrop-blur">
                    Lo más pedido
                  </span>
                )}
              </div>
              <div class="flex flex-1 flex-col gap-3 p-5">
                <h3 class="font-display text-lg font-semibold text-ink">{s.title}</h3>
                <p class="line-clamp-3 text-sm leading-relaxed text-muted">{s.description}</p>
                <ul class="mt-auto flex flex-wrap gap-2 pt-2">
                  {s.bullets.map((b) => (
                    <li class="inline-flex items-center gap-1.5 rounded-full bg-surface px-3 py-1 text-xs text-ink-soft ring-1 ring-border">
                      <Icon name="check" class="size-3.5 text-brand" />
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
      <div class="shrink-0 pr-4" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  #svc-track::-webkit-scrollbar {
    display: none;
  }
  .reel-frame {
    will-change: transform, opacity;
    transform: translate(-50%, -50%);
  }
  /* Reduced motion (any size): skip the reel entirely, show the swipe carousel. */
  @media (prefers-reduced-motion: reduce) {
    #svc-reel {
      display: none;
    }
    .svc-mobile {
      display: block;
    }
  }
</style>

<script>
  import '@/scripts/services-gallery';
</script>
