---
import { services } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';

// Bento spans (lg, 6-col grid). 'ai-automation' is the dark featured tile.
const span: Record<string, string> = {
  'ai-automation': 'lg:col-span-3',
  growth: 'lg:col-span-3',
  media: 'lg:col-span-2',
  fintech: 'lg:col-span-2',
  mobile: 'lg:col-span-2',
  software: 'lg:col-span-6',
};
---

<section id="servicios" class="relative scroll-mt-24 overflow-hidden py-[var(--spacing-section)]">
  <!-- Premium backdrop: faint top grid + soft brand aurora -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="bg-grid absolute inset-x-0 top-0 h-[70%] opacity-50"></div>
    <div
      class="glow-spot"
      style="width:46rem;height:32rem;left:50%;top:-4rem;transform:translateX(-50%);background:oklch(0.62 0.19 264 / 0.1);"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1240px] px-4 sm:px-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="Lo que hacemos por ti"
        title="IA que hace crecer tu negocio, y software que lo sostiene"
        description="Automatizamos, conseguimos clientes y producimos contenido con IA — y construimos el software, las apps y la fintech que lo respaldan. Todo bajo un mismo techo."
      />
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
      {
        services.map((s, i) => {
          const featured = s.id === 'ai-automation';
          return (
            <article
              data-svc-card
              data-spotlight
              class:list={[
                'svc-card-el card-3d edge-top group relative flex flex-col gap-5 overflow-hidden rounded-[var(--radius-card)] p-7 [transform-style:preserve-3d] will-change-transform',
                span[s.id] ?? 'lg:col-span-2',
                featured
                  ? 'glow-brand bg-night text-on-night'
                  : 'border border-border bg-gradient-to-b from-canvas to-surface hover:border-brand/30',
              ]}
            >
              {featured && (
                <>
                  <div class="bg-grid-night pointer-events-none absolute inset-0 rounded-[var(--radius-card)] opacity-40" />
                  {/* slow diagonal light sweep (animated by services-anim) */}
                  <span
                    data-svc-sheen
                    class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-1/2 -skew-x-12 bg-gradient-to-r from-transparent via-white/10 to-transparent"
                  />
                </>
              )}
              <div class="relative flex items-center justify-between">
                <span
                  data-svc-icon
                  class:list={[
                    'grid size-14 place-items-center rounded-2xl shadow-[var(--shadow-soft)] ring-1',
                    featured
                      ? 'bg-gradient-to-br from-brand to-brand-strong text-white ring-white/15'
                      : 'bg-gradient-to-br from-brand-soft to-[oklch(0.9_0.05_264)] text-brand ring-brand/15',
                  ]}
                >
                  <Icon name={s.icon} class="size-7" />
                </span>
                {featured && (
                  <span class="rounded-full border border-white/15 px-3 py-1 text-[11px] uppercase tracking-wider text-on-night-muted">
                    Lo más pedido
                  </span>
                )}
              </div>

              <div class="relative flex flex-col gap-2">
                <h3 class:list={['text-xl', featured ? 'text-on-night' : 'text-ink']}>
                  {s.title}
                </h3>
                <p
                  class:list={[
                    'leading-relaxed',
                    featured ? 'text-on-night-muted' : 'text-muted',
                  ]}
                  style="max-width: 46ch;"
                >
                  {s.description}
                </p>
              </div>

              <ul class="relative mt-auto flex flex-wrap gap-2 pt-1">
                {s.bullets.map((b) => (
                  <li
                    class:list={[
                      'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs',
                      featured
                        ? 'bg-white/8 text-on-night-muted'
                        : 'bg-canvas text-ink-soft ring-1 ring-border',
                    ]}
                  >
                    <Icon name="check" class={featured ? 'size-3.5 text-brand' : 'size-3.5 text-brand'} />
                    {b}
                  </li>
                ))}
              </ul>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  import '@/scripts/services-anim';
</script>
