---
import { services } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';

// Distinct (but cohesive, cool-family) gradient per service for the card visual.
const visual: Record<string, string> = {
  'ai-automation': 'from-[oklch(0.5_0.2_264)] to-[oklch(0.27_0.12_280)]',
  growth: 'from-[oklch(0.52_0.16_210)] to-[oklch(0.29_0.12_235)]',
  media: 'from-[oklch(0.52_0.17_300)] to-[oklch(0.3_0.13_285)]',
  fintech: 'from-[oklch(0.52_0.14_175)] to-[oklch(0.29_0.11_200)]',
  mobile: 'from-[oklch(0.54_0.16_250)] to-[oklch(0.3_0.13_262)]',
  software: 'from-[oklch(0.48_0.19_264)] to-[oklch(0.27_0.13_255)]',
};
const category: Record<string, string> = {
  'ai-automation': 'Automatización',
  growth: 'Marketing IA',
  media: 'Contenido IA',
  fintech: 'Fintech',
  mobile: 'Apps',
  software: 'Software',
};
---

<section id="servicios" class="relative scroll-mt-24 bg-surface">
  <div class="mx-auto max-w-[1240px] px-4 pt-[var(--spacing-section)] sm:px-6">
    <SectionHeading
      eyebrow="Lo que hacemos por ti"
      title="IA que hace crecer tu negocio, y software que lo sostiene"
      description="Desliza para recorrer lo que construimos: automatización, marketing y contenido con IA — y el software, las apps y la fintech que lo respaldan."
    />
  </div>

  <!-- Gallery: desktop = pinned horizontal scroll; mobile = swipe carousel -->
  <div id="svc-gallery" class="relative mt-10 pb-[var(--spacing-section)]">
    <div
      id="svc-track"
      class="flex gap-5 overflow-x-auto px-4 pb-4 [scrollbar-width:none] snap-x snap-mandatory sm:px-6"
    >
      {
        services.map((s) => {
          const featured = s.id === 'ai-automation';
          return (
            <article class="svc-card group relative flex h-[60vh] max-h-[520px] w-[80vw] max-w-[330px] shrink-0 snap-center flex-col overflow-hidden rounded-[var(--radius-xl2)] border border-border bg-canvas card-3d will-change-transform lg:w-[370px]">
              {/* Visual header */}
              <div class:list={['svc-visual relative h-[46%] overflow-hidden bg-gradient-to-br', visual[s.id] ?? visual.software]}>
                <div class="bg-grid-night absolute inset-0 opacity-25" />
                <Icon name={s.icon} class="svc-art pointer-events-none absolute -bottom-10 -right-7 size-48 text-white/10" />
                <span class="absolute left-5 top-5 grid size-12 place-items-center rounded-2xl bg-white/15 text-white ring-1 ring-white/25 backdrop-blur">
                  <Icon name={s.icon} class="size-6" />
                </span>
                <span class="absolute right-5 top-6 text-[11px] font-medium uppercase tracking-[0.16em] text-white/70">
                  {category[s.id]}
                </span>
                {featured && (
                  <span class="absolute bottom-4 left-5 rounded-full bg-white/15 px-3 py-1 text-[11px] font-medium uppercase tracking-wider text-white backdrop-blur">
                    Lo más pedido
                  </span>
                )}
              </div>

              {/* Content */}
              <div class="flex flex-1 flex-col gap-3 p-6">
                <h3 class="font-display text-xl font-semibold leading-snug text-ink">{s.title}</h3>
                <p class="line-clamp-3 text-sm leading-relaxed text-muted">{s.description}</p>
                <ul class="mt-auto flex flex-wrap gap-2 pt-2">
                  {s.bullets.map((b) => (
                    <li class="inline-flex items-center gap-1.5 rounded-full bg-surface px-3 py-1 text-xs text-ink-soft ring-1 ring-border">
                      <Icon name="check" class="size-3.5 text-brand" />
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
      <!-- trailing spacer so the last card can rest centred on desktop -->
      <div class="shrink-0 lg:w-[24vw]" aria-hidden="true"></div>
    </div>

    <!-- desktop scroll-progress -->
    <div class="mx-auto mt-2 hidden h-1 w-40 overflow-hidden rounded-full bg-border lg:block">
      <span id="svc-progress" class="block h-full w-full origin-left scale-x-0 bg-brand"></span>
    </div>
  </div>
</section>

<style>
  .svc-track::-webkit-scrollbar {
    display: none;
  }
  /* Desktop pinned mode: gallery fills the viewport and centres the cards;
     the moving track is clipped. Toggled by services-gallery.ts. */
  .svc-gallery--pinned {
    display: flex;
    min-height: 100vh;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-bottom: 0;
  }
  .svc-track--static {
    overflow: visible;
  }
</style>

<script>
  import '@/scripts/services-gallery';
</script>
