---
import { faqs } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';
---

<section id="faq" class="scroll-mt-24 bg-surface py-[var(--spacing-section)]">
  <div class="mx-auto grid max-w-[1240px] gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
    <SectionHeading
      eyebrow="Preguntas frecuentes"
      title="Lo que sueles preguntarnos antes de empezar"
      description="¿No ves tu duda? Escríbenos y te respondemos el mismo día."
    />

    <div data-reveal class="flex flex-col">
      {
        faqs.map((f) => (
          <details class="group border-b border-border first:border-t">
            <summary
              class="press flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-lg font-medium text-ink"
            >
              {f.q}
              <span class="grid size-8 shrink-0 place-items-center rounded-full border border-border bg-canvas text-brand">
                <Icon
                  name="plus"
                  class="faq-plus size-4 transition-transform duration-300 ease-[var(--ease-snappy)]"
                />
              </span>
            </summary>
            <div class="disclosure">
              <div>
                <p class="pb-5 pr-10 leading-relaxed text-muted" style="max-width: 64ch;">
                  {f.a}
                </p>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
