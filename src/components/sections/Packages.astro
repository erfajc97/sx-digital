---
import { packages } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
---

<section id="planes" class="scroll-mt-24 py-[var(--spacing-section)]">
  <div class="mx-auto max-w-[1240px] px-4 sm:px-6">
    <SectionHeading
      align="center"
      eyebrow="Formas de trabajar juntos"
      title="Elige el ritmo que tu proyecto necesita"
      description="Desde una pieza puntual hasta un equipo dedicado. Precios honestos desde la primera llamada."
    />

    <!-- Mobile: compact swipe (featured plan first, peek of the next).
         Desktop: 3-col grid. -->
    <div
      class="pkg-track mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 [scrollbar-width:none] lg:mt-12 lg:grid lg:grid-cols-3 lg:items-stretch lg:gap-5 lg:overflow-visible lg:pb-0"
    >
      {
        packages.map((p, i) => {
          const featured = p.featured;
          return (
            <article
              data-reveal
              style={`--reveal-delay: ${i * 90}ms;`}
              class:list={[
                'card-3d edge-top relative flex w-[78vw] max-w-[300px] shrink-0 snap-center flex-col gap-4 overflow-hidden rounded-[var(--radius-xl2)] p-6 sm:gap-6 sm:p-8 lg:w-auto lg:max-w-none',
                featured ? 'order-first lg:order-none' : '',
                featured
                  ? 'glow-brand bg-night text-on-night lg:-translate-y-4'
                  : 'card-3d-hover border border-border bg-surface',
              ]}
            >
              <div class="flex items-center justify-between">
                <h3 class:list={['font-display text-xl', featured ? 'text-on-night' : 'text-ink']}>
                  {p.name}
                </h3>
                {featured && (
                  <span class="rounded-full bg-brand px-3 py-1 text-[11px] font-medium uppercase tracking-wider text-white">
                    Recomendado
                  </span>
                )}
              </div>

              <div class="flex flex-col gap-1">
                <span class:list={['font-display text-2xl font-semibold sm:text-3xl', featured ? 'text-gradient' : 'text-ink']}>
                  {p.price}
                </span>
                <span class:list={['text-sm', featured ? 'text-on-night-muted' : 'text-muted']}>
                  {p.cadence}
                </span>
              </div>

              <p class:list={['leading-relaxed', featured ? 'text-on-night-muted' : 'text-muted']}>
                {p.description}
              </p>

              <ul class="flex flex-col gap-2.5 border-t pt-4 sm:gap-3 sm:pt-5"
                  class:list={featured ? 'border-white/10' : 'border-border'}>
                {p.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-sm">
                    <Icon name="check" class="mt-0.5 size-4 shrink-0 text-brand" />
                    <span class={featured ? 'text-on-night-muted' : 'text-ink-soft'}>{f}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-auto pt-2">
                <Button
                  href="#agenda"
                  cal
                  size="lg"
                  variant={featured ? 'on-night' : 'ghost'}
                  class="w-full"
                >
                  {p.cta}
                </Button>
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Mobile swipe position dots (also a "this scrolls" affordance) -->
    <div id="pkg-dots" class="mt-1 flex justify-center gap-2.5 lg:hidden">
      {
        packages.map((_, i) => (
          <button
            type="button"
            class="pkg-dot size-2 rounded-full bg-ink/25 transition-all"
            aria-current={i === 0 ? 'true' : 'false'}
            aria-label={`Ir al plan ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .pkg-track::-webkit-scrollbar {
    display: none;
  }
  .pkg-dot[aria-current='true'] {
    width: 1.5rem;
    border-radius: 9999px;
    background-color: var(--color-brand);
  }
</style>

<script>
  // Sync the dots with the mobile swipe (visual order — the featured plan is
  // reordered first via CSS) and let a tap jump to that plan.
  const track = document.querySelector<HTMLElement>('.pkg-track');
  const wrap = document.getElementById('pkg-dots');
  if (track && wrap) {
    const dots = Array.from(wrap.querySelectorAll<HTMLButtonElement>('button'));
    const items = Array.from(track.querySelectorAll<HTMLElement>('article')).sort(
      (a, b) => a.offsetLeft - b.offsetLeft
    );
    let raf = 0;
    const update = () => {
      raf = 0;
      const mid = track.scrollLeft + track.clientWidth / 2;
      let best = 0;
      let bd = Infinity;
      items.forEach((el, i) => {
        const d = Math.abs(el.offsetLeft + el.offsetWidth / 2 - mid);
        if (d < bd) {
          bd = d;
          best = i;
        }
      });
      dots.forEach((d, i) => d.setAttribute('aria-current', i === best ? 'true' : 'false'));
    };
    track.addEventListener(
      'scroll',
      () => {
        if (!raf) raf = requestAnimationFrame(update);
      },
      { passive: true }
    );
    dots.forEach((d, i) =>
      d.addEventListener('click', () => {
        const el = items[i];
        track.scrollTo({
          left: el.offsetLeft - (track.clientWidth - el.offsetWidth) / 2,
          behavior: 'smooth',
        });
      })
    );
    update();
  }
</script>
