---
import { differentiators, stats } from '@/data/site';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';
---

<section class="py-[var(--spacing-section)]">
  <div class="mx-auto max-w-[1240px] px-4 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <SectionHeading
        eyebrow="Por qué SolvyX"
        title="La diferencia entre contratar a un proveedor y a un socio"
        description="Trabajamos como una extensión de tu equipo. Pocos clientes a la vez, foco total en cada uno."
      />

      <div class="flex flex-col divide-y divide-border">
        {
          differentiators.map((d, i) => (
            <div
              data-reveal
              style={`--reveal-delay: ${i * 80}ms;`}
              class="flex items-start gap-5 py-6 first:pt-0"
            >
              <span class="grid size-11 shrink-0 place-items-center rounded-2xl bg-brand-soft text-brand">
                <Icon name={d.icon} class="size-5" />
              </span>
              <div class="flex flex-col gap-1.5">
                <h3 class="text-lg text-ink">{d.title}</h3>
                <p class="leading-relaxed text-muted" style="max-width: 54ch;">
                  {d.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Stats band -->
    <div class="relative mt-16 overflow-x-clip">
      <div
        class="glow-spot"
        style="width:36rem;height:18rem;left:50%;top:35%;transform:translate(-50%,-50%);background:oklch(0.52 0.193 264 / 0.16);"
        aria-hidden="true"
      >
      </div>
      <dl
        data-reveal
        class="card-3d edge-top relative grid grid-cols-2 gap-px overflow-hidden rounded-[var(--radius-xl2)] border border-border bg-border lg:grid-cols-4"
      >
        {
          stats.map((s) => {
            const n = parseFloat(s.value.replace(/[^\d.]/g, ''));
            // Only animate "real" numbers: big counts, a decimal (8.4), or a ratio (×).
            // (Guard against the period in abbreviations like "2 sem.")
            const countup = /\d/.test(s.value) && (n >= 10 || s.value.includes('×') || /\d\.\d/.test(s.value));
            return (
              <div class="group flex flex-col gap-1.5 bg-canvas p-7 transition-colors duration-300 hover:bg-surface">
                <dt
                  class="text-gradient font-display text-[clamp(2.2rem,4vw,3rem)] font-semibold leading-none tabular-nums"
                  data-countup={countup ? '' : undefined}
                >
                  {s.value}
                </dt>
                <dd class="text-sm leading-snug text-muted">{s.label}</dd>
              </div>
            );
          })
        }
      </dl>
    </div>
  </div>
</section>
