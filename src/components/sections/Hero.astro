---
import Icon from '../ui/Icon.astro';
import { getDict, defaultLocale, type Locale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const { hero, heroMedia, brand, ui } = getDict(locale);

const sp = hero.servicePrompt;
---

<section id="hero" class="relative min-h-[100svh] overflow-hidden bg-night lg:min-h-[100dvh]">
  <!-- Background video — full-bleed; autoplay + loop -->
  <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
    <video
      id="hero-video"
      class="size-full object-cover object-[15%_center] md:object-right"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={heroMedia.poster}
      data-poster-mobile={heroMedia.posterMobile}
      data-src-mobile={heroMedia.videoMobile}
      width="1600"
      height="896"
      aria-hidden="true"
    >
      {/* Desktop / web (16:9). On small screens the JS swaps to the vertical clip
          (the <source media> attribute is ignored inside <video>, so we do it in JS). */}
      {heroMedia.videoWebm && <source src={heroMedia.videoWebm} type="video/webm" />}
      <source src={heroMedia.video} type="video/mp4" />
    </video>
  </div>

  <!-- Dark scrim for text contrast (darker where the text is) -->
  <div class="hero-scrim pointer-events-none absolute inset-0 z-[1]"></div>
  <!-- Top band so the navbar always reads over the video -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-[2] h-28 sm:h-32"
    style="background: linear-gradient(to bottom, oklch(0.13 0.02 265 / 0.7), transparent);"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto flex min-h-[100svh] w-full max-w-7xl flex-col justify-between px-6 pb-7 pt-16 sm:px-8 sm:pb-6 sm:pt-24 lg:min-h-[100dvh] lg:justify-center lg:py-0"
  >
    <div class="max-w-xl lg:max-w-2xl">
      <!-- Headline: static h1 (SEO + reduced-motion + no-JS), swapped to the
           particle canvas when motion is allowed. -->
      <h1
        id="hero-fallback"
        data-reveal
        class="mb-3 max-w-[16ch] font-display text-[clamp(1.85rem,7vw,4.5rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-on-night sm:mb-6 sm:leading-[1.04]"
      >
        {hero.fallbackHeadline}
      </h1>
      <canvas
        id="hero-particles"
        class="mb-3 hidden h-auto w-full max-w-[40rem] sm:mb-4"
        data-words={JSON.stringify(hero.particleWords)}
        aria-hidden="true"></canvas>

      <!-- secondary -->
      <p
        data-reveal
        style="--reveal-delay: 120ms; max-width: 46ch;"
        class="mb-4 line-clamp-3 text-sm leading-relaxed text-on-night-muted sm:mb-8 sm:line-clamp-none sm:text-lg"
      >
        {hero.lead}
      </p>

      <!-- secondary link — hidden on mobile to keep the hero within one screen -->
      <div data-reveal style="--reveal-delay: 200ms;" class="mt-1 hidden sm:block">
        <a
          href={hero.secondaryCta.href}
          class="group inline-flex w-fit items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-on-night backdrop-blur-sm transition-colors hover:border-white/30 hover:text-white"
        >
          {hero.secondaryCta.label}
          <Icon
            name="arrow"
            class="size-4 transition-transform duration-200 ease-[var(--ease-snappy)] group-hover:translate-x-0.5"
          />
        </a>
      </div>
    </div>

    <!-- bottom group: a light service prompt that floats directly over the
         video (no boxed container) so the clip keeps the spotlight -->
    <div data-reveal style="--reveal-delay: 180ms;" class="max-w-xl lg:mt-8 lg:max-w-2xl">
      <p class="mb-2 text-sm font-medium text-on-night sm:mb-3">
        {sp.title}
        <span class="text-on-night-muted">· {ui.heroUi.selectHint}</span>
      </p>

      <div class="mb-4 flex flex-wrap gap-1.5 sm:mb-6 sm:gap-2">
        {
          sp.options.map((opt) => (
            <button
              type="button"
              class="svc-pill press inline-flex items-center gap-1 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium text-on-night backdrop-blur-sm transition-colors duration-200 ease-[var(--ease-snappy)] hover:bg-white/12 sm:gap-1.5 sm:px-3.5 sm:py-1.5 sm:text-sm"
              data-service={opt.label}
              aria-pressed="false"
            >
              <Icon name={opt.icon} class="pill-ico size-3.5 shrink-0 text-brand" />
              {opt.label}
            </button>
          ))
        }
      </div>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <a
          href={brand.bookingUrl}
          data-cal-link={brand.calLink}
          data-cal-namespace={brand.calNamespace}
          data-cal-config='{"layout":"month_view"}'
          class="btn-3d inline-flex items-center gap-2 rounded-full bg-brand px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-strong sm:px-7 sm:py-3.5 sm:text-base"
        >
          {ui.heroUi.cta}
          <Icon name="arrow" class="size-4" />
        </a>
        <span id="svc-list" class="text-sm text-on-night-muted" data-prefix={ui.heroUi.selectedPrefix}></span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Dark scrim — vertical on mobile (text top + pills bottom), horizontal on
     desktop (dark left where the text sits, video visible on the right). */
  .hero-scrim {
    background: linear-gradient(
      to bottom,
      oklch(0.16 0.02 265 / 0.72) 0%,
      oklch(0.16 0.02 265 / 0.38) 30%,
      oklch(0.16 0.02 265 / 0.12) 62%,
      oklch(0.16 0.02 265 / 0.3) 100%
    );
  }
  @media (min-width: 1024px) {
    .hero-scrim {
      background: linear-gradient(
        to right,
        oklch(0.17 0.02 265 / 0.92) 0%,
        oklch(0.17 0.02 265 / 0.55) 45%,
        oklch(0.17 0.02 265 / 0.12) 78%,
        transparent 100%
      );
    }
  }

  /* Glass card — subtle refraction edge */
  .svc-card {
    box-shadow:
      0 24px 60px -18px oklch(0.1 0.02 265 / 0.7),
      inset 0 1px 0 oklch(1 0 0 / 0.08);
  }

  /* Pills — active turns cobalt, icon goes white */
  .svc-pill {
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .svc-pill[aria-pressed='true'] {
    background-color: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
    box-shadow: var(--shadow-soft);
  }
  .svc-pill[aria-pressed='true'] .pill-ico {
    color: #fff;
  }

  /* Status banner springs its height open */
  .svc-banner {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.4s var(--ease-snappy),
      opacity 0.3s ease;
  }
  .svc-banner > div {
    overflow: hidden;
  }
  .svc-banner.is-active {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  #svc-placeholder.is-hidden {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-pill,
    .svc-banner {
      transition: none;
    }
  }
</style>

<script>
  import '@/scripts/particle-text';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Hero background video: autoplay/loop, poster on reduced-motion
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video) {
    // On small screens, swap to the vertical (9:16) clip + poster.
    if (window.matchMedia('(max-width: 767px)').matches && video.dataset.srcMobile) {
      if (video.dataset.posterMobile) video.poster = video.dataset.posterMobile;
      video.innerHTML = '';
      const s = document.createElement('source');
      s.src = video.dataset.srcMobile;
      s.type = 'video/mp4';
      video.appendChild(s);
      video.load();
    }
    if (reduce) {
      video.removeAttribute('autoplay');
      video.pause();
    } else {
      video.muted = true;
      video.play().catch(() => {
        /* poster fallback */
      });
    }
  }

  // Interactive service pills (multi-select) → inline summary next to the CTA
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-service]'));
  const list = document.getElementById('svc-list');
  const selected = new Set<string>();

  const sync = () => {
    if (list)
      list.textContent = selected.size
        ? `${list.dataset.prefix ?? ''} ${Array.from(selected).join(', ')}`
        : '';
  };

  pills.forEach((p) => {
    p.addEventListener('click', () => {
      const v = p.getAttribute('data-service') || '';
      const on = p.getAttribute('aria-pressed') === 'true';
      p.setAttribute('aria-pressed', String(!on));
      if (on) selected.delete(v);
      else selected.add(v);
      sync();
    });
  });
</script>
