---
import Icon from './Icon.astro';
import type { IconName } from '@/data/site';
import { brand } from '@/data/site';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'on-night';
  icon?: IconName;
  size?: 'md' | 'lg';
  class?: string;
  external?: boolean;
  /** When true, the link opens the global contact modal (with #agenda fallback). */
  openContact?: boolean;
  /** When true, the link opens the Cal.com booking modal (no-JS → booking page). */
  cal?: boolean;
}

const {
  href,
  variant = 'primary',
  icon,
  size = 'md',
  class: className = '',
  external = false,
  openContact = false,
  cal = false,
} = Astro.props;

// Cal buttons: open the popup modal via data-cal-link; the href points to the
// public booking page so it still works without JS.
const calAttrs = cal
  ? {
      'data-cal-link': brand.calLink,
      'data-cal-namespace': brand.calNamespace,
      'data-cal-config': JSON.stringify({ layout: 'month_view' }),
    }
  : {};
const finalHref = cal ? brand.bookingUrl : href;
// Cal buttons keep href as a no-JS fallback but must NOT open a new tab —
// Cal intercepts the click to open the modal in place.
const isExternal = external;

const base =
  'btn-3d group inline-flex items-center justify-center gap-2 rounded-full font-medium focus-visible:outline-2';

const sizes = {
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const variants = {
  primary: 'bg-brand text-white hover:bg-brand-strong',
  secondary: 'bg-ink text-canvas hover:bg-ink-soft',
  ghost: 'text-ink hover:bg-surface-2 border border-border',
  'on-night': 'bg-canvas text-ink hover:bg-on-night-muted',
};

const rel = isExternal ? 'noopener noreferrer' : undefined;
const target = isExternal ? '_blank' : undefined;
---

<a
  href={finalHref}
  rel={rel}
  target={target}
  data-open-contact={openContact ? '' : undefined}
  {...calAttrs}
  class:list={[base, sizes[size], variants[variant], className]}
>
  <slot />
  {
    icon && (
      <Icon
        name={icon}
        class="size-4 transition-transform duration-200 ease-[var(--ease-snappy)] group-hover:translate-x-0.5"
      />
    )
  }
</a>
