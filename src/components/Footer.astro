---
import { brand, footer } from '@/data/site';
import Icon from './ui/Icon.astro';
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-[1240px] px-4 py-16 sm:px-6">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div class="flex flex-col gap-5">
        <img src={brand.logo3d} alt={brand.name} class="h-11 w-auto self-start" width="441" height="233" />
        <p class="max-w-sm leading-relaxed text-muted">{footer.blurb}</p>
        <div class="flex flex-col gap-2 text-sm text-ink-soft">
          <a href={`mailto:${brand.email}`} class="inline-flex w-fit items-center gap-2 hover:text-brand">
            <Icon name="mail" class="size-4" />
            {brand.email}
          </a>
          <span class="inline-flex items-center gap-2">
            <Icon name="pin" class="size-4 text-muted" />
            {brand.location}
          </span>
        </div>
      </div>

      {
        footer.columns.map((col) => (
          <nav class="flex flex-col gap-3">
            <h3 class="font-display text-sm uppercase tracking-[0.14em] text-muted">
              {col.title}
            </h3>
            <ul class="flex flex-col gap-2.5">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-ink-soft transition-colors hover:text-brand"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div
      class="mt-14 flex flex-col gap-4 border-t border-border pt-6 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {new Date().getFullYear()} {brand.name}. Todos los derechos reservados.</p>
      <ul class="flex flex-wrap gap-5">
        {
          brand.social.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors hover:text-ink"
              >
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
